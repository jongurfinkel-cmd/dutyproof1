# DutyProof — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URL ────────────────────────────────────────────────
# Used for SMS links, webhook validation, and redirect URLs.
# In production: https://dutyproof.com
# In development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Twilio (SMS) ──────────────────────────────────────────
# Used for check-in reminders, escalation alerts, and consent SMS.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18884093780

# ─── Stripe (Billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID=your-stripe-price-id

# ─── Resend (Email) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cron ───────────────────────────────────────────────────
# Secret used to authenticate /api/cron/check-missed.
# Generate with: openssl rand -hex 16
# IMPORTANT: Pass via Authorization header (Bearer) or x-cron-secret header. Never as query param.
CRON_SECRET=your-cron-secret
